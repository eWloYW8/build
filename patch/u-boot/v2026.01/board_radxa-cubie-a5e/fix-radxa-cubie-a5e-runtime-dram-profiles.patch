 arch/arm/mach-sunxi/Kconfig                   |   8 ++
 arch/arm/mach-sunxi/dram_sun55i_a523.c        | 108 ++++++++++++------
 arch/arm/mach-sunxi/dram_timings/a523_ddr3.c  |   3 +-
 .../arm/mach-sunxi/dram_timings/a523_lpddr4.c |  20 ++--
 configs/radxa-cubie-a5e_defconfig             |   1 +
 6 files changed, 101 insertions(+), 49 deletions(-)

