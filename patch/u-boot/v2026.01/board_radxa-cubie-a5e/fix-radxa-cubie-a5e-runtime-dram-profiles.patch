--- a/arch/arm/include/asm/arch-sunxi/dram_sun55i_a523.h
+++ b/arch/arm/include/asm/arch-sunxi/dram_sun55i_a523.h
@@ -136,6 +136,14 @@ struct dram_config {
 	u8 bus_full_width;
 	u32 clk;
 	u32 odt_en;
+	u8 mr1;
+	u8 mr2;
+	u8 mr3;
+	u8 mr4;
+	u8 mr11;
+	u8 mr12;
+	u8 mr14;
+	u8 mr22;
 	u32 tpr11;
 	u32 tpr12;
 	u32 tpr14;
@@ -148,6 +156,6 @@ static inline int ns_to_t(int nanoseconds, u32 clk)
 	return DIV_ROUND_UP(ctrl_freq * nanoseconds, 1000);
 }
 
-void mctl_set_timing_params(u32 clk);
+void mctl_set_timing_params(const struct dram_config *config);
 
 #endif /* _SUNXI_DRAM_SUN55I_T527_H */
diff --git a/arch/arm/mach-sunxi/Kconfig b/arch/arm/mach-sunxi/Kconfig
index e979ee4a..5109d2dd 100644
--- a/arch/arm/mach-sunxi/Kconfig
+++ b/arch/arm/mach-sunxi/Kconfig
@@ -62,6 +62,14 @@ config DRAM_SUN55I_A523
 	help
 	  Select this DRAM controller driver for A523/T527 SoCs.
 
+config RADXA_CUBIE_A5E_DRAM_PROFILES
+	bool "Use Radxa Cubie A5E capacity-based DRAM profiles"
+	depends on MACH_SUN55I_A523 && SUNXI_DRAM_A523_LPDDR4
+	help
+	  Use Radxa Cubie A5E DRAM parameters selected by detected memory
+	  size. The 1GB LPDDR4 board uses a different timing profile from
+	  the LPDDR4x 2GB/4GB boards.
+
 if DRAM_SUN50I_H616 || DRAM_SUN50I_A133 || DRAM_SUN55I_A523
 config DRAM_SUNXI_DX_ODT
 	hex "DRAM DX ODT parameter"
diff --git a/arch/arm/mach-sunxi/dram_sun55i_a523.c b/arch/arm/mach-sunxi/dram_sun55i_a523.c
index 1ffb6286..047a1b96 100644
