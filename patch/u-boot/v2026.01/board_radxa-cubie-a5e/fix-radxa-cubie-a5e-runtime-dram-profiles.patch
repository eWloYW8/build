+++ b/arch/arm/mach-sunxi/dram_timings/a523_lpddr4.c
@@ -10,12 +10,12 @@
 #include <asm/arch/dram.h>
 #include <asm/arch/cpu.h>
 
-void mctl_set_timing_params(u32 clk)
+void mctl_set_timing_params(const struct dram_config *config)
 {
 	struct sunxi_mctl_ctl_reg * const mctl_ctl =
 			(struct sunxi_mctl_ctl_reg *)SUNXI_DRAM_CTL0_BASE;
 	u8 tcl, tcwl, t_rdata_en, trtp, twr, tphy_wrlat;
-	unsigned int mr1, mr2;
+	u32 clk = config->clk;
 
 	u8 tccd		= 4;
 	u8 tfaw		= ns_to_t(40, clk);
@@ -37,9 +37,7 @@ void mctl_set_timing_params(u32 clk)
 	u8 tcksre	= max(ns_to_t(5, clk), 2);
 	u8 trasmax	= (trefi * 9) / 32;
 
-	if (clk <= 936) {
-		mr1 = 0x34;
-		mr2 = 0x1b;
+	if (config->mr1 == 0x34 && config->mr2 == 0x1b) {
 		tcl = 10;
 		tcwl = 5;
 		t_rdata_en = 17;
@@ -47,8 +45,6 @@ void mctl_set_timing_params(u32 clk)
 		tphy_wrlat = 5;
 		twr = 10;
 	} else if (clk <= 1200) {
-		mr1 = 0x54;
-		mr2 = 0x2d;
 		tcl = 14;
 		tcwl = 7;
 		t_rdata_en = 25;
@@ -56,8 +52,6 @@ void mctl_set_timing_params(u32 clk)
 		tphy_wrlat = 9;
 		twr = 15;
 	} else {
-		mr1 = 0x64;
-		mr2 = 0x36;
 		tcl = 16;
 		tcwl = 8;
 		t_rdata_en = 29;
@@ -102,10 +96,10 @@ void mctl_set_timing_params(u32 clk)
 	writel(0x01f20000, &mctl_ctl->init[1]);
 	writel(0x00001705, &mctl_ctl->init[2]);
 	writel(0, &mctl_ctl->dfimisc);
-	writel((mr1 << 16) | mr2, &mctl_ctl->init[3]);
-	writel(0x00330000, &mctl_ctl->init[4]);
-	writel(0x00040072, &mctl_ctl->init[6]);
-	writel(0x00260008, &mctl_ctl->init[7]);
+	writel((config->mr1 << 16) | config->mr2, &mctl_ctl->init[3]);
+	writel(config->mr3 << 16, &mctl_ctl->init[4]);
+	writel((config->mr11 << 16) | config->mr12, &mctl_ctl->init[6]);
+	writel((config->mr22 << 16) | config->mr14, &mctl_ctl->init[7]);
 
 	clrsetbits_le32(&mctl_ctl->rankctl, 0xff0, 0x660);
 
diff --git a/configs/radxa-cubie-a5e_defconfig b/configs/radxa-cubie-a5e_defconfig
