+++ b/arch/arm/mach-sunxi/dram_sun55i_a523.c
@@ -193,20 +193,13 @@ static void mctl_phy_configure_odt(const struct dram_para *para)
 static bool mctl_phy_write_leveling(const struct dram_para *para,
 				    const struct dram_config *config)
 {
-	u32 mr2, low, high, val = 0;
+	u32 low, high, val = 0;
 	bool result = true;
 
 	clrsetbits_le32(SUNXI_DRAM_PHY0_BASE + 4, 0xf00, 0xe00);
 
-	if (para->type == SUNXI_DRAM_TYPE_LPDDR4) {
-		if (config->clk <= 936)
-			mr2 = 0x1b;
-		else if (config->clk <= 1200)
-			mr2 = 0x2d;
-		else
-			mr2 = 0x36;
-		writeb(mr2, SUNXI_DRAM_PHY0_BASE + 3);
-	}
+	if (para->type == SUNXI_DRAM_TYPE_LPDDR4)
+		writeb(config->mr2, SUNXI_DRAM_PHY0_BASE + 3);
 
 	low = readw(SUNXI_DRAM_PHY0_BASE + 2) | 4;
 	high = readw(SUNXI_DRAM_PHY0_BASE + 4);
@@ -924,7 +917,7 @@ static bool mctl_phy_init(const struct dram_para *para,
 	struct sunxi_mctl_ctl_reg * const mctl_ctl =
 			(struct sunxi_mctl_ctl_reg *)SUNXI_DRAM_CTL0_BASE;
 	void *const prcm = (void *)SUNXI_PRCM_BASE;
-	u32 val, val2, mr1, mr2;
+	u32 val, val2;
 	int i;
 
 	clrbits_le32(prcm + CCU_PRCM_SYS_PWROFF_GATING, 1);
@@ -1187,42 +1180,31 @@ static bool mctl_phy_init(const struct dram_para *para,
 		mctl_await_completion(&mctl_ctl->mrctrl0, BIT(31), 0);
 		break;
 	case SUNXI_DRAM_TYPE_LPDDR4:
-		if (config->clk <= 936) {
-			mr1 = 0x34;
-			mr2 = 0x1b;
-		} else if (config->clk <= 1200) {
-			mr1 = 0x54;
-			mr2 = 0x2d;
-		} else {
-			mr1 = 0x64;
-			mr2 = 0x36;
-		}
-
 		writel(0x0, &mctl_ctl->mrctrl1);
 		writel(0x800000f0, &mctl_ctl->mrctrl0);
 		mctl_await_completion(&mctl_ctl->mrctrl0, BIT(31), 0);
 
-		writel(0x100 | mr1, &mctl_ctl->mrctrl1);
+		writel(0x100 | config->mr1, &mctl_ctl->mrctrl1);
 		writel(0x800000f0, &mctl_ctl->mrctrl0);
 		mctl_await_completion(&mctl_ctl->mrctrl0, BIT(31), 0);
 
-		writel(0x200 | mr2, &mctl_ctl->mrctrl1);
+		writel(0x200 | config->mr2, &mctl_ctl->mrctrl1);
 		writel(0x800000f0, &mctl_ctl->mrctrl0);
 		mctl_await_completion(&mctl_ctl->mrctrl0, BIT(31), 0);
 
-		writel(0x333, &mctl_ctl->mrctrl1);
+		writel(0x300 | config->mr3, &mctl_ctl->mrctrl1);
 		writel(0x800000f0, &mctl_ctl->mrctrl0);
 		mctl_await_completion(&mctl_ctl->mrctrl0, BIT(31), 0);
 
-		writel(0x403, &mctl_ctl->mrctrl1);
+		writel(0x400 | config->mr4, &mctl_ctl->mrctrl1);
 		writel(0x800000f0, &mctl_ctl->mrctrl0);
 		mctl_await_completion(&mctl_ctl->mrctrl0, BIT(31), 0);
 
-		writel(0xb04, &mctl_ctl->mrctrl1);
+		writel(0xb00 | config->mr11, &mctl_ctl->mrctrl1);
 		writel(0x800000f0, &mctl_ctl->mrctrl0);
 		mctl_await_completion(&mctl_ctl->mrctrl0, BIT(31), 0);
 
-		writel(0xc72, &mctl_ctl->mrctrl1);
+		writel(0xc00 | config->mr12, &mctl_ctl->mrctrl1);
 		writel(0x800000f0, &mctl_ctl->mrctrl0);
 		mctl_await_completion(&mctl_ctl->mrctrl0, BIT(31), 0);
 
@@ -1230,11 +1212,11 @@ static bool mctl_phy_init(const struct dram_para *para,
 		writel(0x800000f0, &mctl_ctl->mrctrl0);
 		mctl_await_completion(&mctl_ctl->mrctrl0, BIT(31), 0);
 
-		writel(0xe08, &mctl_ctl->mrctrl1);
+		writel(0xe00 | config->mr14, &mctl_ctl->mrctrl1);
 		writel(0x800000f0, &mctl_ctl->mrctrl0);
 		mctl_await_completion(&mctl_ctl->mrctrl0, BIT(31), 0);
 
-		writel(0x1626, &mctl_ctl->mrctrl1);
+		writel(0x1600 | config->mr22, &mctl_ctl->mrctrl1);
 		writel(0x800000f0, &mctl_ctl->mrctrl0);
 		mctl_await_completion(&mctl_ctl->mrctrl0, BIT(31), 0);
 		break;
@@ -1353,7 +1335,7 @@ static bool mctl_ctrl_init(const struct dram_para *para,
 
 	mctl_set_addrmap(config);
 
-	mctl_set_timing_params(config->clk);
+	mctl_set_timing_params(config);
 
 	writel(0, &mctl_ctl->pwrctl);
 
@@ -1412,6 +1394,59 @@ static const struct dram_para para = {
 	.tpr10 = CONFIG_DRAM_SUNXI_TPR10,
 };
 
+static void mctl_set_lpddr4_mr_defaults(struct dram_config *config)
+{
+	if (config->clk <= 936) {
+		config->mr1 = 0x34;
+		config->mr2 = 0x1b;
+	} else if (config->clk <= 1200) {
+		config->mr1 = 0x54;
+		config->mr2 = 0x2d;
+	} else {
+		config->mr1 = 0x64;
+		config->mr2 = 0x36;
+	}
+
+	config->mr3 = 0x33;
+	config->mr4 = 0x03;
+	config->mr11 = 0x04;
+	config->mr12 = 0x72;
+	config->mr14 = 0x08;
+	config->mr22 = 0x26;
+}
+
+static void mctl_apply_radxa_cubie_a5e_profile(struct dram_para *para,
+					       struct dram_config *config,
+					       unsigned long size)
+{
+	if (!IS_ENABLED(CONFIG_RADXA_CUBIE_A5E_DRAM_PROFILES))
+		return;
+
+	config->mr1 = 0x34;
+	config->mr2 = 0x1b;
+	config->mr3 = 0x33;
+	config->mr4 = 0x03;
+	config->mr11 = 0x04;
+	config->mr12 = 0x72;
+	config->mr22 = 0x26;
+
+	if (size <= 0x40000000UL) {
+		para->tpr2 = 0x1f0b0503;
+		para->tpr6 = 0x3a000000;
+		config->tpr11 = 0xc0c0bbbf;
+		config->tpr12 = 0x35352f31;
+		config->mr14 = 0x0e;
+	} else {
+		para->tpr2 = 0x5f090503;
+		para->tpr6 = 0x38000000;
+		config->tpr11 = 0xc6c4c2c0;
+		config->tpr12 = 0x3a373233;
+		config->mr14 = 0x0c;
+	}
+
+	config->tpr14 = 0x48484848;
+}
+
 static void sunxi_nsi_init(void)
 {
 	/* IOMMU prio 3 */
@@ -1470,6 +1505,7 @@ static void init_something(void)
 
 unsigned long sunxi_dram_init(void)
 {
+	struct dram_para final_para = para;
 	struct dram_config config;
 	unsigned long size;
 
@@ -1486,6 +1522,7 @@ unsigned long sunxi_dram_init(void)
 		config.tpr11 = 0x9a9a9a9a;
 		config.tpr12 = 0x0e0f070a;
 		config.tpr14 = 0x48484848;
+		mctl_set_lpddr4_mr_defaults(&config);
 		break;
 	default:
 		panic("This DRAM setup is currently not supported.\n");
@@ -1496,16 +1533,19 @@ unsigned long sunxi_dram_init(void)
 
 	mctl_auto_detect_rank_width(&para, &config);
 	mctl_auto_detect_dram_size(&para, &config);
+	size = mctl_calc_size(&config);
 
 	config.clk = CONFIG_DRAM_CLK;
 	config.odt_en = CONFIG_DRAM_SUNXI_ODT_EN;
 	config.tpr11 = CONFIG_DRAM_SUNXI_TPR11;
 	config.tpr12 = CONFIG_DRAM_SUNXI_TPR12;
 	config.tpr14 = CONFIG_DRAM_SUNXI_TPR14;
+	if (para.type == SUNXI_DRAM_TYPE_LPDDR4) {
+		mctl_set_lpddr4_mr_defaults(&config);
+		mctl_apply_radxa_cubie_a5e_profile(&final_para, &config, size);
+	}
 
-	mctl_core_init(&para, &config);
-
-	size = mctl_calc_size(&config);
+	mctl_core_init(&final_para, &config);
 
 	sunxi_nsi_init();
 	init_something();
